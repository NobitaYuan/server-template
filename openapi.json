            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "用户已删除",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "number"
                    },
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": [
                        "object",
